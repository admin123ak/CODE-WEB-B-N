# =============================================
# LOCAL CONFIG - KHÔNG BAO GIỜ PUSH SECRET LÊN GIT
# =============================================
config.local.php
.install_lock
.env
!.env.example

# =============================================
# DATA - RUNTIME STATE & DATABASE DUMPS THẬT
# =============================================
data/*.json
data/*.log
data/*.lock
data/locks/
data/ratelimit/
data/login_attempts/
!data/.gitkeep

# Uploads (admin upload images) - giữ thư mục nhưng không push file
uploads/games/*
!uploads/games/.gitkeep
!uploads/.htaccess
!uploads/.gitkeep

# Database dumps có data thật của khách hàng
hcloucom_bankey.sql
*_dump.sql
*_backup.sql

# =============================================
# BACKUP FILES
# =============================================
.backups_original/
*.bk
*.bk1
*.bk2
*.bk3
*.bk_*
*.backup

# =============================================
# LOGS
# =============================================
*.log
logs/

# =============================================
# DEPENDENCIES
# =============================================
node_modules/
vendor/

# =============================================
# IDE / OS
# =============================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================
# TEMP
# =============================================
*.tmp
*.temp
*.cache
tmp/
